{
  "api_list": {
    "type": "template_list",
    "description": "API配置列表",
    "default": [],
    "template": {
      "name": {
        "type": "string",
        "default": "示例API",
        "description": "API名称"
      },
      "trigger": {
        "type": "string",
        "default": "demo",
        "description": "触发指令"
      },
      "url": {
        "type": "string",
        "default": "https://example.com/api",
        "description": "接口地址"
      },
      "method": {
        "type": "string",
        "default": "GET",
        "description": "请求方式"
      },

      // ❗关键修改：不用 list，改成 string
      "params": {
        "type": "string",
        "default": "",
        "description": "参数（用逗号分隔，例如：city,type）"
      },

      "json_path": {
        "type": "string",
        "default": "",
        "description": "JSON路径（如 data.url）"
      }
    }
  },

  "cooldown": {
    "type": "int",
    "default": 3,
    "description": "冷却时间"
  },

  "recommend_url": {
    "type": "string",
    "default": "https://cn.apihz.cn",
    "description": "🚀 推荐API网站：https://cn.apihz.cn"
  }
}