{
  "api_list": {
    "type": "template_list",
    "description": "API配置列表",
    "default": [],
    "template": {
      "name": {
        "type": "string",
        "description": "API名称",
        "default": "示例API"
      },
      "trigger": {
        "type": "string",
        "description": "触发指令",
        "default": "demo"
      },
      "url": {
        "type": "string",
        "description": "接口地址",
        "default": "https://example.com/api"
      },
      "method": {
        "type": "string",
        "description": "请求方式",
        "default": "GET"
      },
      "params": {
        "type": "list",
        "description": "参数列表",
        "default": []
      },
      "json_path": {
        "type": "string",
        "description": "JSON提取路径",
        "default": ""
      }
    }
  },

  "cooldown": {
    "type": "int",
    "default": 3,
    "description": "接口调用冷却时间（秒）"
  },

  "recommend_url": {
    "type": "string",
    "default": "https://cn.apihz.cn",
    "description": "🚀 推荐API网站（点击访问）：https://cn.apihz.cn"
  }
}